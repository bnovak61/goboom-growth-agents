# GTM Automation Agents - Environment Variables
# Copy this file to .env and fill in your API keys

# ===================
# PhantomBuster
# ===================
PHANTOM_BUSTER_API_KEY=

# ===================
# Instantly (Email)
# ===================
INSTANTLY_API_KEY=

# ===================
# Apollo.io
# ===================
APOLLO_API_KEY=

# ===================
# Million Verifier
# ===================
MILLION_VERIFIER_API_KEY=

# ===================
# Facebook Ads
# ===================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT_ID=

# ===================
# Notion
# ===================
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ===================
# Slack
# ===================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ===================
# Perplexity AI
# ===================
PERPLEXITY_API_KEY=

# ===================
# Rephonic (Podcasts)
# ===================
REPHONIC_API_KEY=

# ===================
# Redis (for BullMQ)
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# Application
# ===================
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
