{
  "name": "goboom-growth-agents",
  "version": "1.0.0",
  "description": "GTM Automation Agents for marketing, sales, and growth workflows",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:api": "tsc",
    "build:ui": "cd ui && npm run build",
    "dev": "tsx watch src/index.ts",
    "dev:ui": "cd ui && npm run dev",
    "start": "node dist/index.js",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/workers/cron-scheduler.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "job:optimize-ads": "tsx src/agents/facebook-ads-optimizer/cli.ts optimize",
    "job:generate-ads": "tsx src/agents/facebook-ads-generator/cli.ts generate",
    "job:analyze-ppc": "tsx src/agents/google-ads-ppc/cli.ts",
    "agent:ppc": "tsx src/agents/google-ads-ppc/cli.ts",
    "mcp:start": "tsx src/mcp/server.ts",
    "start:orchestrator": "tsx src/workers/cron-scheduler.ts --orchestrator"
  },
  "keywords": [
    "gtm",
    "automation",
    "marketing",
    "sales",
    "growth",
    "agents"
  ],
  "author": "GoBoom",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.99.0",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-ads-api": "^23.0.0",
    "googleapis": "^171.4.0",
    "ky": "^1.7.2",
    "p-limit": "^6.1.0",
    "p-retry": "^6.2.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "puppeteer": "^23.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "eslint": "^9.10.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
